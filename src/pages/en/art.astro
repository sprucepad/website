---
import Gallery from "@/components/Gallery.svelte";
import Layout from "@/layouts/Layout.astro";

import { getCollection } from "@/lib/custom-collection";
import { art } from "@/lib/mappers";

const locale = Astro.currentLocale ?? "en";

const albums = await getCollection("art");
---

<Layout title="sprucepad's gallery" desc="My pixel art gallery.">
  <Gallery
    images={albums.flatMap(art(locale))}
    empty="Nothing here yet!"
    placeholder="Search gallery..."
    client:load
  />
</Layout>

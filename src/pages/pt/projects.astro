---
import Layout from "@/layouts/Layout.astro";
import Cards from "@/components/Cards.svelte";

import { getCollectionWithImage } from "@/lib/collection-w-image";

const topics = await getCollectionWithImage("topics", "icon");
const cards = await getCollectionWithImage("projects", "image");
---

<Layout title="projetos por sprucepad" desc="Meus projetos de programação.">
  <h1 class="font-heading text-4xl">Projetos</h1>

  <Cards {cards} {topics} client:load />
</Layout>

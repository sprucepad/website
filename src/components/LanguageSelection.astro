<select id="language-select">
  <option value="pt" selected={Astro.currentLocale?.startsWith("pt")}
    >Português</option
  >
  <option value="en" selected={Astro.currentLocale?.startsWith("en")}
    >English</option
  >
</select>

<script>
  const languageSelect = document.getElementById(
    "language-select",
  ) as HTMLSelectElement;

  languageSelect.addEventListener("change", () => {
    const url = new URL(location.href);
    const pathname = url.pathname.split("/").slice(2).join("/");

    location.href = `/${languageSelect.value}/${pathname}`;
  });
</script>

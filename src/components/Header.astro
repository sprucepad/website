---
import { getRelativeLocaleUrl } from "astro:i18n";

import t from "@/i18n";
import { cn } from "@/lib/utils";
const locale = Astro.currentLocale ?? "pt";

const items = [
  { label: t("nav.home", locale), href: getRelativeLocaleUrl(locale, "/") },
  {
    label: t("nav.projects", locale),
    href: getRelativeLocaleUrl(locale, "/projects"),
  },
  { label: t("nav.art", locale), href: getRelativeLocaleUrl(locale, "/art") },
  {
    label: t("nav.posts", locale),
    href: getRelativeLocaleUrl(locale, "/posts"),
  },
];
---

<header class="fixed p-4" transition:name="header">
  <nav>
    <menu class="flex gap-1">
      {
        items.map(({ href, label }) => {
          const active =
            href === "/"
              ? Astro.url.pathname === href
              : Astro.url.pathname.startsWith(href);
          return (
            <li>
              <a class={cn("p-2", active && "bg-accent neobrutal")} {href}>
                {label}
              </a>
            </li>
          );
        })
      }
    </menu>
  </nav>
</header>

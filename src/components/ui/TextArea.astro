---
import { cn } from "@/lib/utils";
import type { HTMLAttributes } from "astro/types";
import { cva, type VariantProps } from "class-variance-authority";

const textareaStyles = cva("h-32 p-2 focus:outline-2 focus:outline-accent", {
  variants: {
    variant: {
      art: "rounded-lg neobrutal",
      code: "border-1",
    },
  },
});

interface Props
  extends VariantProps<typeof textareaStyles>, HTMLAttributes<"textarea"> {}

const { variant, class: className, ...rest } = Astro.props;

const slotContent = await Astro.slots.render("default");
---

<textarea
  class={cn(textareaStyles({ variant }), className)}
  set:html={slotContent}
  {...rest}
/>

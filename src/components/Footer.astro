  <div class="opacity-50">
    <p>
      Copyright &copy; 2026-{new Date().getFullYear()} sprucepad. Under two different
      licenses:
    </p>
    <ul class="ml-4 list-disc">
      <li>
        Code: <a
          href="https://opensource.org/licenses/mit"
          rel="noopener noreferrer"
          target="_blank"
          class="underline">MIT License</a
        >
      </li>
      <li>
        Content (assets, images, artwork, audio, text, etc.): <a
          href="https://github.com/sprucepad/website/tree/main/content/LICENSE.txt"
          rel="noopener noreferrer"
          target="_blank"
          class="underline">All Rights Reserved</a
        >, unless stated otherwise
      </li>
      <li>
        Fonts: <a
          href="https://openfontlicense.org/"
          rel="noopener noreferrer"
          target="_blank"
          class="underline">SIL Open Font License (OFL) 1.1</a
